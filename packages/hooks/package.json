{
  "name": "@tideline/hooks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tideline-codex-hook": "./dist/codex-hook-adapter.js",
    "tideline-hook": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codex-hook-adapter": {
      "types": "./dist/codex-hook-adapter.d.ts",
      "import": "./dist/codex-hook-adapter.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "pnpm --filter @tideline/core build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @tideline/core build && pnpm run build && node --test \"test/**/*.test.mjs\"",
    "typecheck": "pnpm --filter @tideline/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tideline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.0"
  }
}
