{
  "name": "@tideline/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tideline-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @tideline/core build && tsc -p tsconfig.build.json",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "pnpm --filter @tideline/core build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build",
    "typecheck": "pnpm --filter @tideline/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tideline/core": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0"
  }
}
