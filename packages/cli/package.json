{
  "name": "@tideline/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "tideline": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @tideline/hooks build && pnpm --filter @tideline/mcp build && pnpm run build && node --test \"test/**/*.test.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.20.0"
  }
}
